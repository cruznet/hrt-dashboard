{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hrt-dashboard",
  "main": "worker.js",
  "compatibility_date": "2026-06-29",
  "triggers": {
    "crons": ["0 6 * * *", "0 14 * * *", "0 20 * * *"]
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "exclude": [".git", ".wrangler", "node_modules", ".github", ".gitignore", ".DS_Store"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
